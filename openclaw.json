{
  "name": "openclaw",
  "provider": "groq",
  "models": {
    "hermes": {
      "model": "openai/gpt-oss-120b",
      "api_key": "${GROQ_API_KEY}"
    },
    "openclaw": {
      "model": "llama-3.3-70b-versatile",
      "api_key": "${GROQ_API_KEY}"
    }
  },
  "slack": {
    "bot_token": "${SLACK_BOT_TOKEN}",
    "app_token": "${SLACK_APP_TOKEN}"
  },
  "settings": {
    "environment": "local",
    "log_channel": "#agent-log",
    "task_channel": "#agent-coder",
    "planner_channel": "#sprint-main"
  }
}
